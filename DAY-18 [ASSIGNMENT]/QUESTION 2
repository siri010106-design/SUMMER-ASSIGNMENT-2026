#include <iostream>
using namespace std;
int main()
{
    int a[5] = {7, 2, 9, 1, 5};
    int x, y, z, t;
    for(x = 0; x < 4; x++)
    {
        z = x;
        for(y = x + 1; y < 5; y++)
        {
            if(a[y] < a[z])
            {
                z = y;
            }
        }
        t = a[x];
        a[x] = a[z];
        a[z] = t;
    }
    cout << "Sorted Array: ";
    for(x = 0; x < 5; x++)
    {
        cout << a[x] << " ";
    } 
    return 0;
}
