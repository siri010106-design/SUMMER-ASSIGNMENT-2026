#include<iostream>
using namespace std;
int main()
{
    int a[10][10], n, m;
    cout<<"Enter rows and columns: ";
    cin>>n>>m;
    for(int i=0; i<n; i++)
    {
        for(int j=0; j<m; j++)
        {
            cin>>a[i][j];
        }
    }
    for(int j=0; j<m; j++)
    {
        int s = 0;
        for(int i=0; i<n; i++)
        {
            s = s + a[i][j];
        }
        cout<<"Sum = "<<s<<endl;
    }
    return 0;
}
