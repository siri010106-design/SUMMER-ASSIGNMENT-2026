#include<iostream>
using namespace std;
int main()
{
    int m[10][10];
    int row, col, total;
    cout<<"Enter rows and columns: ";
    cin>>row>>col;
    cout<<"Enter matrix elements:\n";
    for(int i=0; i<row; i++)
    {
        for(int j=0; j<col; j++)
        {
            cin>>m[i][j];
        }
    }
    for(int i=0; i<row; i++)
    {
        total = 0;
        for(int j=0; j<col; j++)
        {
            total = total + m[i][j];
        }
        cout<<"Row "<<i+1<<" Sum = "<<total<<endl;
    }
    return 0;
}
