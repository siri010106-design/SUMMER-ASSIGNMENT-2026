#include<iostream>
using namespace std;
int main()
{
    char s[100];
    int i, j, c;
    cout<<"Enter string: ";
    cin>>s;
    for(i=0; s[i]!='\0'; i++)
    {
        c = 0;
        for(j=0; s[j]!='\0'; j++)
        {
            if(s[i] == s[j])
            {
                c++;
            }
        }
        if(c == 1)
        {
            cout<<"First non-repeating character = "<<s[i];
            break;
        }
    }
    return 0;
}
