#include<iostream>
using namespace std;
int main()
{
    char s1[100], s2[100], t;
    int i, j, n1=0, n2=0;
    cout<<"Enter first string: ";
    cin>>s1;
    cout<<"Enter second string: ";
    cin>>s2;
    for(i=0; s1[i]!='\0'; i++)
        n1++;
    for(i=0; s2[i]!='\0'; i++)
        n2++;
    if(n1 != n2)
    {
        cout<<"Not Anagram";
        return 0;
    }
    for(i=0; i<n1-1; i++)
    {
        for(j=i+1; j<n1; j++)
        {
            if(s1[i] > s1[j])
            {
                t = s1[i];
                s1[i] = s1[j];
                s1[j] = t;
            }
            if(s2[i] > s2[j])
            {
                t = s2[i];
                s2[i] = s2[j];
                s2[j] = t;
            }
        }
    }
    for(i=0; i<n1; i++)
    {
        if(s1[i] != s2[i])
        {
            cout<<"Not Anagram";
            return 0;
        }
    }
    cout<<"Anagram";
    return 0;
}
