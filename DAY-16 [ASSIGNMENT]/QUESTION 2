#include <iostream>
using namespace std;
int main() {
    int n[5], x, y, c, high = 0, ans;
    cout << "Enter 5 elements: ";
    for (x = 0; x < 5; x++) {
        cin >> n[x];
    }
    for (x = 0; x < 5; x++) {
        c = 1;
        for (y = x + 1; y < 5; y++) {
            if (n[x] == n[y]) {
                c++;
            }
        }
        if (c > high) {
            high = c;
            ans = n[x];
        }
    }
    cout << "Element with maximum frequency = " << ans << endl;
    cout << "Frequency = " << high;
    return 0;
}
