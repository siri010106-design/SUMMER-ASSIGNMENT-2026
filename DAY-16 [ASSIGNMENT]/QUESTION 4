#include <iostream>
using namespace std;
int main() {
    int n[5], i, j, check;
    cout << "Enter 5 elements: ";
    for (i = 0; i < 5; i++) {
        cin >> n[i];
    }
    cout << "Array after removing duplicates: ";
    for (i = 0; i < 5; i++) {
        check = 0;
        for (j = 0; j < i; j++) {
            if (n[i] == n[j]) {
                check = 1;
                break;
            }
        }
        if (check == 0) {
            cout << n[i] << " ";
        }
    }
    return 0;
}
