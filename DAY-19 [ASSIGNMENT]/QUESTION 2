#include <iostream>
using namespace std;
int main() {
    int r, c;
    cout << "Enter rows and columns: ";
    cin >> r >> c;
    int x[10][10], y[10][10], ans[10][10];
    cout << "Enter first matrix:\n";
    for (int i = 0; i < r; i++) {
        for (int j = 0; j < c; j++) {
            cin >> x[i][j];
        }
    }
    cout << "Enter second matrix:\n";
    for (int i = 0; i < r; i++) {
        for (int j = 0; j < c; j++) {
            cin >> y[i][j];
        }
    }
    cout << "Subtraction of matrices:\n";
    for (int i = 0; i < r; i++) {
        for (int j = 0; j < c; j++) {
            ans[i][j] = x[i][j] - y[i][j];
            cout << ans[i][j] << " ";
        }
        cout << endl;
    }
    return 0;
}
