#include<iostream>
using namespace std;
int main()
{
    int a[10][10], n, s = 0;
    cout << "Enter size of matrix: ";
    cin >> n;
    cout << "Enter elements:\n";
    for(int i = 0; i < n; i++)
    {
        for(int j = 0; j < n; j++)
        {
            cin >> a[i][j];
        }
    }
    for(int i = 0; i < n; i++)
    {
        s = s + a[i][i];
    }
    cout << "Sum of diagonal = " << s;
    return 0;
}
