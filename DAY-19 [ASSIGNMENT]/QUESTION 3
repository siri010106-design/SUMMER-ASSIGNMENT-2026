#include <iostream>
using namespace std;
int main()
{
    int mat[10][10], trans[10][10];
    int row, col;
    cout << "Enter rows: ";
    cin >> row;
    cout << "Enter columns: ";
    cin >> col;
    cout << "Enter matrix elements:\n";
    for(int i = 0; i < row; i++)
    {
        for(int j = 0; j < col; j++)
        {
            cin >> mat[i][j];
        }
    }
    for(int i = 0; i < row; i++)
    {
        for(int j = 0; j < col; j++)
        {
            trans[j][i] = mat[i][j];
        }
    }
    for(int i = 0; i < col; i++)
    {
        for(int j = 0; j < row; j++)
        {
            cout << trans[i][j] << " ";
        }
        cout << endl;
    }
    return 0;
}
