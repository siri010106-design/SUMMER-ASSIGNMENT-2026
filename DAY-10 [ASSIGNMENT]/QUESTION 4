#include <iostream>
using namespace std;
int main()
{
    int a;
    cout << "Enter the number of rows: ";
    cin >> a;
    for (int i = 1; i <= a; i++)
    {
        for (int p = 1; p <= a - i; p++)
        {
            cout << " ";
        }
        char ch = 'A';
        for (int j = 1; j <= i; j++)
        {
            cout << ch;
            ch++;
        }
        ch = ch - 2;
        for (int k = 1; k < i; k++)
        {
            cout << ch;
            ch--;
        }
        cout << endl;
    }
    return 0;
}
