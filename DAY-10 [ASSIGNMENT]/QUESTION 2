#include <iostream>
using namespace std;
int main()
{
    int a;
    cout << "Enter the number of rows: ";
    cin >> a;
    for (int i = a; i >= 1; i--)
    {
        for (int p = 1; p <= a - i; p++)
        {
            cout << " ";
        }
        for (int j = 1; j <= 2 * i - 1; j++)
        {
            cout << "*";
        }
        cout << endl;
    }
    return 0;
}
