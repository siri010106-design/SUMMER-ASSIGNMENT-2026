#include <iostream>
using namespace std;
int main()
{
    int a, b, result = 1;
    cout << "Enter the number: ";
    cin >> a;
    cout << "Enter the power: ";
    cin >> b;
    for (int i = 1; i <= b; i++)
    {
        result = result * a;
    }
    cout << "Answer = " << result;
    return 0;
}
