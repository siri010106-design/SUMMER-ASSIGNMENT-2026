#include<iostream>
using namespace std;
int main()
{
    char name[50];
    int k;
    cout<<"Enter string: ";
    cin>>name;
    for(k=0; name[k]!='\0'; k++)
    {
        if(name[k]>='a' && name[k]<='z')
        {
            name[k] = name[k] - 32;
        }
    }
    cout<<"Uppercase String = "<<name;
    return 0;
}
