#include<iostream>
using namespace std;
int main()
{
    char s[50];
    int v = 0, c = 0, i;
    cout<<"Enter string: ";
    cin>>s;
    for(i = 0; s[i] != '\0'; i++)
    {
        if(s[i]=='a' || s[i]=='e' || s[i]=='i' || s[i]=='o' || s[i]=='u' ||
           s[i]=='A' || s[i]=='E' || s[i]=='I' || s[i]=='O' || s[i]=='U')
        {
            v++;
        }
        else
        {
            c++;
        }
    }
    cout<<"Vowels = "<<v<<endl;
    cout<<"Consonants = "<<c;
    return 0;
}
