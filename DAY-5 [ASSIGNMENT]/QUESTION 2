#include <iostream>
using namespace std;
int main()
{
    int p, temp, rem;
    int sum = 0;
    cout << "Enter a number: ";
    cin >> p;
    temp = p;
    while (temp > 0)
    {
        rem = temp % 10;
        int fact = 1;
        for (int i = 1; i <= rem; i++)
        {
            fact = fact * i;
        }
        sum = sum + fact;
        temp = temp / 10;
    }
    if (sum == p)
    {
        cout << p << " is a Strong Number.";
    }
    else
    {
        cout << p << " is not a Strong Number.";
    }
    return 0;
}
