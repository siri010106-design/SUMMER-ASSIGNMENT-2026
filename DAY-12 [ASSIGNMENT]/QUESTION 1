#include <iostream>
using namespace std;
int a(int x)
{
    int temp = x;
    int r = 0;
    while (x != 0)
    {
        int d = x % 10;
        r = r * 10 + d;
        x = x / 10;
    }
    if (temp == r)
        return 1;
    else
        return 0;
}
int main()
{
    int n;
    cout << "Enter number: ";
    cin >> n;

    if (a(n))
        cout << "Palindrome";
    else
        cout << "Not Palindrome";
    return 0;
}
