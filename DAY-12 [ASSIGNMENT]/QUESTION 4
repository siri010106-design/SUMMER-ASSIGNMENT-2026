#include <iostream>
using namespace std;
int p(int n)
{
    int sum = 0;
    for (int i = 1; i < n; i++)
    {
        if (n % i == 0)
            sum = sum + i;
    }
    if (sum == n)
        return 1;
    else
        return 0;
}
int main()
{
    int num;
    cout << "Enter a number: ";
    cin >> num;
    if (p(num))
        cout << "Perfect Number";
    else
        cout << "Not a Perfect Number";
    return 0;
}
