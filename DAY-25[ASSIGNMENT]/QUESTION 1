#include <iostream>
using namespace std;
int main()
{
    int n, m;
    cout << "Enter size of first array: ";
    cin >> n;
    int a[n];
    cout << "Enter sorted elements: ";
    for (int i = 0; i < n; i++)
        cin >> a[i];
    cout << "Enter size of second array: ";
    cin >> m;
    int b[m];
    cout << "Enter sorted elements: ";
    for (int i = 0; i < m; i++)
        cin >> b[i];
    int c[n + m];
    int p = 0, q = 0, r = 0;
    while (p < n && q < m)
    {
        if (a[p] <= b[q])
        {
            c[r] = a[p];
            p++;
        }
        else
        {
            c[r] = b[q];
            q++;
        }
        r++;
    }
    while (p < n)
    {
        c[r] = a[p];
        p++;
        r++;
    }
    while (q < m)
    {
        c[r] = b[q];
        q++;
        r++;
    }
    cout << "Merged Array: ";
    for (int i = 0; i < n + m; i++)
        cout << c[i] << " ";
    return 0;
}
