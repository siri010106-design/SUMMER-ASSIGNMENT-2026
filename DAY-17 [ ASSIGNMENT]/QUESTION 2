#include <iostream>
using namespace std;
int main()
{
    int a[4] = {1, 2, 3, 4};
    int b[4] = {3, 4, 5, 6};
    cout << "Union Array: ";
    for(int i = 0; i < 4; i++)
    {
        cout << a[i] << " ";
    }
    for(int i = 0; i < 4; i++)
    {
        if(b[i] != 3 && b[i] != 4 && b[i] != 4)
        {
            cout << b[i] << " ";
        }
    }
    return 0;
}
