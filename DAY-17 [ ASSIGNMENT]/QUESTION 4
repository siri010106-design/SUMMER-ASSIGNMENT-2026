#include <iostream>
using namespace std;
int main()
{
    int a[4] = {2, 4, 6, 8};
    int b[4] = {1, 4, 5, 8};
    cout << "Common Elements: ";
    for(int i = 0; i < 4; i++)
    {
        for(int j = 0; j < 4; j++)
        {
            if(a[i] == b[j])
            {
                cout << a[i] << " ";
            }
        }
    }
    return 0;
}
