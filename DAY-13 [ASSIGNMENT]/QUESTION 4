#include <iostream>
using namespace std;
int main()
{
    int a[5], i, even = 0, odd = 0;
    cout << "Enter 5 numbers: ";
    for(i = 0; i < 5; i++)
    {
        cin >> a[i];
        if(a[i] % 2 == 0)
            even++;
        else
            odd++;
    }
    cout << "Even elements = " << even << endl;
    cout << "Odd elements = " << odd << endl;
    return 0;
}
