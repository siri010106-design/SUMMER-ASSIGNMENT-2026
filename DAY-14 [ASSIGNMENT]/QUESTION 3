#include <iostream>
using namespace std;
int main()
{
    int a[5], i, first, second;
    cout << "Enter 5 elements: ";
    for(i = 0; i < 5; i++)
    {
        cin >> a[i];
    }
    first = second = a[0];
    for(i = 1; i < 5; i++)
    {
        if(a[i] > first)
        {
            second = first;
            first = a[i];
        }
        else if(a[i] > second && a[i] != first)
        {
            second = a[i];
        }
    }
    cout << "Second largest element = " << second;
    return 0;
}
