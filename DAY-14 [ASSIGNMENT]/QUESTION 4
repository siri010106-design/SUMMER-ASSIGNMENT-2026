#include <iostream>
using namespace std;
int main()
{
    int num[5], i, j;
    cout << "Enter 5 elements: ";
    for(i = 0; i < 5; i++)
    {
        cin >> num[i];
    }
    cout << "Duplicate elements are: ";
    for(i = 0; i < 5; i++)
    {
        for(j = i + 1; j <5; j++)
        {
            if(num[i] == num[j])
            {
                cout << num[i] << " ";
                break;
            }
        }
    }
    return 0;
}
