#include <iostream>
using namespace std;
int main()
{
    int a;
    cout << "Enter the number of rows: ";
    cin >> a;
    for (int i = 1; i <= a; i++)
    {
        char ch = 'A' + i - 1;
        for (int j = 1; j <= i; j++)
        {
            cout << ch;
        }
        cout << endl;
    }
    return 0;
}
