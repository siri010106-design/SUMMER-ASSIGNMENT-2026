#include <iostream>
using namespace std;
int main() {
    int arr[10], a;
    cout << "Enter number of elements: ";
    cin >> a;
    cout << "Enter array elements: ";
    for (int i = 0; i <a; i++) {
        cin >> arr[i];
    }
    cout << "Reversed array: ";
    for (int i = a - 1; i >= 0; i--) {
        cout << arr[i] << " ";
    }
    return 0;
}
