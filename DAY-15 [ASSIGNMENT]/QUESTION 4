#include <iostream>
using namespace std;
int main()
{
    int n, a[5], b;
    cout << "Enter size: ";
    cin >> n;
    cout << "Enter elements: ";
    for (int i = 0; i < n; i++)
    {
        cin >> a[i];
    }
    for (int i = 0; i < n; i++)
    {
        if (a[i] == 0)
        {
            for (int j = i; j < n - 1; j++)
            {
               b = a[j];
                a[j] = a[j + 1];
                a[j + 1] = b;
            }
            i--;
        }
    }
    cout << "Array after moving zeroes to end: ";
    for (int i = 0; i < n; i++)
    {
        cout << a[i] << " ";
    }
    return 0;
}
