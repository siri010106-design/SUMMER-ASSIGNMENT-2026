#include <iostream>
using namespace std;
int main()
{
    int p, i, count = 0;
    cout << "Enter a number: ";
    cin >> p;
    for(i = 1; i <= p; i++)
    {
        if(p % i == 0)
        {
            count++;
        }
    }
    if(count == 2)
    {
        cout << "Prime Number";
    }
    else
    {
        cout << "Not a Prime Number";
    }
    return 0;
}
